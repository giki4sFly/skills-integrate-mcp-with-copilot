# Example environment variables for local development
# Copy this file to .env and fill in real values before running the app.

# Database - either provide a single DATABASE_URL or the individual parts
# Example URL: postgresql://username:password@localhost:5432/activities_db
DATABASE_URL=

# (Optional) Individual DB settings if you prefer:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=activities_db
DB_USERNAME=
DB_PASSWORD=

# JWT settings used by the API
APP_JWT_SECRET=
APP_JWT_EXPIRATION_MS=86400000

# Optional: GitHub token for automation (keep secret, do NOT commit real token)
# GITHUB_TOKEN=
